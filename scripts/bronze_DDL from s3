CREATE TABLE IF NOT EXISTS CRM_CUST_INFO 
USING TEMPLATE (
    SELECT ARRAY_AGG(OBJECT_CONSTRUCT(*))
    FROM TABLE (
            INFER_SCHEMA(
                LOCATION => '@stage_crm/cust_info.csv',
                FILE_FORMAT =>'my_csv_format' 
            )
    )
);

